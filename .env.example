# GraphClaw Cockpit — Environment Variables

# Backend API URL (for Vite dev server proxy target)
# In Docker: leave empty (nginx proxies to gateway:8000)
# In local dev: http://localhost:8000
VITE_API_URL=http://localhost:8000

# Docker Compose — Backend Infrastructure
DB_PASSWORD=graphclaw_dev
MINIO_PASSWORD=graphclaw_dev
ANTHROPIC_API_KEY=
GRAPHCLAW_USER_ID=test-user
