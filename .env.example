# Copy to .env.local for local development. Never commit .env.local.

# Set to "true" to show the Dev Token button on the login page.
# Only effective when the backend also has ENVIRONMENT=development.
# Leave unset (or set to "false") for all cloud deployments.
VITE_ENABLE_DEV_AUTH=false

# Browser log level: debug | info | warn | error
# Defaults to "debug" in dev mode, "info" in production builds.
VITE_LOG_LEVEL=info
