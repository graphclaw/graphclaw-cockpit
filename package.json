{
  "name": "graphclaw-cockpit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:puppeteer": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config e2e-puppeteer/jest.config.cjs",
    "test:e2e:puppeteer:ci": "CI=true node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config e2e-puppeteer/jest.config.cjs --forceExit --bail",
    "seed:puppeteer": "npx tsx e2e-puppeteer/fixtures/seed-all.ts",
    "teardown:puppeteer": "npx tsx e2e-puppeteer/fixtures/teardown-all.ts",
    "regen-inventory": "node scripts/regen-inventory.mjs",
    "check-headers": "node scripts/check-test-headers.mjs",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toggle": "^1.1.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cytoscape": "^3.33.2",
    "cytoscape-dagre": "^2.5.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@eslint/js": "^9.13.0",
    "@jest/test-sequencer": "^29.7.0",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/cytoscape": "^3.21.9",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "jsdom": "^25.0.0",
    "msw": "^2.13.3",
    "pg": "^8.20.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "puppeteer": "^22.15.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.10.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
