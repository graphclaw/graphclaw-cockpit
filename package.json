{
  "name": "graphclaw-cockpit",
  "private": true,
  "version": "0.1.2",
  "description": "GraphClaw Cockpit — React 19 + TypeScript SPA for the GraphClaw task graph management system",
  "license": "Apache-2.0",
  "author": "GraphClaw Contributors",
  "homepage": "https://graphclaw.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graphclaw/graphclaw-cockpit.git"
  },
  "bugs": {
    "url": "https://github.com/graphclaw/graphclaw-cockpit/issues"
  },
  "keywords": [
    "graphclaw",
    "task-management",
    "graph",
    "ai-agents",
    "react",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "regen-inventory": "node scripts/regen-inventory.mjs",
    "check-headers": "node scripts/check-test-headers.mjs",
    "test:coverage": "vitest run --coverage",
    "seed": "npx tsx e2e/seed/seed-all.ts",
    "teardown": "npx tsx e2e/seed/teardown-all.ts",
    "sync-openapi": "curl -sf http://localhost:8000/openapi.json -o src/test/openapi.json && echo 'openapi.json updated'",
    "gen:api": "openapi-typescript src/test/openapi.json -o src/lib/api-types.ts",
    "test:contract": "vitest run src/test/contract/"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@hookform/resolvers": "^5.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toggle": "^1.1.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-virtual": "^3.13.26",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cytoscape": "^3.33.4",
    "cytoscape-dagre": "^3.0.0",
    "date-fns": "^4.3.0",
    "lucide-react": "^1.17.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.16.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/cytoscape": "^3.31.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.10.1",
    "pg": "^8.21.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
